{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    { "source": "/api/todos/:id", "destination": "/api/todos/[id]" },
    { "source": "/api/todos", "destination": "/api/todos/index" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
